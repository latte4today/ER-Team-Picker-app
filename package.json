{
  "name": "eternal-return-team-picker",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Desktop app for Eternal Return team composition recommendations.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "cmd /d /s /c start \"\" \"%CD%\\node_modules\\electron\\dist\\electron.exe\" --no-sandbox \"%CD%\"",
    "app": "cmd /d /s /c start \"\" \"%CD%\\node_modules\\electron\\dist\\electron.exe\" --no-sandbox \"%CD%\"",
    "collect-dak": "\"C:\\Program Files\\nodejs\\node.exe\" tools/dak_collector.mjs --rankers 200 --matchesPerRanker 12",
    "collect-official": "node tools/official_collector.mjs",
    "collect-official-seeds": "node tools/official_seed_collector.mjs",
    "build-official-stats": "node tools/build_official_stats.mjs",
    "check-api-key": "node tools/check_api_key.mjs",
    "test-official-api": "node tools/test_api.mjs",
    "wiki-template": "\"C:\\Program Files\\nodejs\\node.exe\" tools/make_wiki_metrics_template.mjs",
    "wiki-apply": "\"C:\\Program Files\\nodejs\\node.exe\" tools/apply_wiki_metrics_csv.mjs",
    "dist": "electron-builder --win nsis",
    "pack": "electron-builder --dir",
    "clean-build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"foreach ($path in @('dist','release')) { if (Test-Path -LiteralPath $path) { Remove-Item -LiteralPath $path -Recurse -Force } }\"",
    "package-win": "npm run clean-build && electron-builder --dir",
    "installer-win": "npm run clean-build && electron-builder --win nsis"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.er.team-picker",
    "productName": "ER Team Picker",
    "files": [
      "index.html",
      "src/**/*",
      "assets/**/*",
      "electron/**/*",
      "supabase/**/*",
      "README.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "latte4today",
        "repo": "ER-Team-Picker-app"
      }
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ER Team Picker",
      "deleteAppDataOnUninstall": false,
      "include": "installer/custom.nsh"
    }
  }
}
