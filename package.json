{
  "name": "eternal-return-team-picker",
  "version": "0.1.5",
  "private": true,
  "description": "Desktop app for Eternal Return team composition recommendations.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "cmd /d /s /c start \"\" \"%CD%\\node_modules\\electron\\dist\\electron.exe\" --no-sandbox \"%CD%\"",
    "app": "cmd /d /s /c start \"\" \"%CD%\\node_modules\\electron\\dist\\electron.exe\" --no-sandbox \"%CD%\"",
    "collect-dak": "\"C:\\Program Files\\nodejs\\node.exe\" tools/dak_collector.mjs --rankers 200 --matchesPerRanker 12",
    "dist": "electron-builder --win portable",
    "pack": "electron-builder --dir",
    "clean-build": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"foreach ($path in @('dist','release')) { if (Test-Path -LiteralPath $path) { Remove-Item -LiteralPath $path -Recurse -Force } }\"",
    "package-win": "npm run clean-build && electron-builder --dir",
    "installer-win": "npm run package-win && \"C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe\" installer\\ERTeamPicker.iss"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.er.team-picker",
    "productName": "ER Team Picker",
    "files": [
      "index.html",
      "src/**/*",
      "assets/**/*",
      "electron/**/*",
      "supabase/**/*",
      "README.md"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}
